# Copy to .env.local (dev) or set in Vercel dashboard (prod).
# See initial-setup.md for full provisioning steps.

# Neon Postgres — the "pooled" connection string works for both runtime and
# migrations. See https://neon.tech/docs/connect/connect-from-any-app
DATABASE_URL="postgres://user:password@host.neon.tech/dbname?sslmode=require"

# Auth.js. Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Only set AUTH_URL locally. In Vercel, LEAVE THIS UNSET on Production/Preview
# — Auth.js auto-detects from VERCEL_URL + the request host. Setting it to
# localhost in prod will send every magic-link callback to your laptop.
AUTH_URL="http://localhost:3000"

# Resend for magic-link email delivery.
AUTH_RESEND_KEY=""
AUTH_EMAIL_FROM="Task Manager <no-reply@your-verified-domain.com>"

# The single email address permitted to sign in. Any other address will be
# silently blocked at the Auth.js signIn callback.
ALLOWED_EMAIL=""
