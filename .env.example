# Copy to .env.local (dev) or set in Vercel dashboard (prod).
# See initial-setup.md for full provisioning steps.

# Neon Postgres — the "pooled" connection string works for both runtime and
# migrations. See https://neon.tech/docs/connect/connect-from-any-app
DATABASE_URL="postgres://user:password@host.neon.tech/dbname?sslmode=require"

# Auth.js. Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Only set AUTH_URL locally. In Vercel, LEAVE THIS UNSET on Production/Preview
# — Auth.js auto-detects from VERCEL_URL + the request host. Setting it to
# localhost in prod will send every OAuth callback to your laptop.
AUTH_URL="http://localhost:3000"

# GitHub OAuth App credentials. Register the app at
# https://github.com/settings/developers → New OAuth App and copy both values.
# See initial-setup.md §3 for the callback URL to register.
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# The single email address permitted to sign in. Must match the *primary*
# email on your GitHub account (the one GitHub returns via the /user API).
# If your GitHub primary email is private, that value is
# `NNNNN+username@users.noreply.github.com` — use that here, or make your
# primary email public. Comparison is case-insensitive.
ALLOWED_EMAIL=""
